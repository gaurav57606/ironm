// Replace [YOUR_ADMIN_UID_PLACEHOLDER] with your Firebase UID before deploying.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /entitlements/{uid} {
      allow read: if request.auth.uid == resource.data.userId || request.auth.uid == '[YOUR_ADMIN_UID_PLACEHOLDER]';
      allow write: if request.auth.uid == '[YOUR_ADMIN_UID_PLACEHOLDER]';
    }

    match /gyms/{uid}/members/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /gyms/{uid}/payments/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /gyms/{uid}/attendance/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /gyms/{uid}/plans/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /gyms/{uid}/backups/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}